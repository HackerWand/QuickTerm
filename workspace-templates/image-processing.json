{
  "version": "1.0",
  "name": "图片处理",
  "groups": [
    {
      "id": 1,
      "name": "EXIF 信息查看",
      "workspaceId": 0
    },
    {
      "id": 2,
      "name": "EXIF 信息编辑",
      "workspaceId": 0
    },
    {
      "id": 3,
      "name": "图片转换",
      "workspaceId": 0
    },
    {
      "id": 4,
      "name": "批量处理",
      "workspaceId": 0
    },
    {
      "id": 5,
      "name": "图片元数据",
      "workspaceId": 0
    }
  ],
  "commands": [
    {
      "id": 1,
      "name": "查看 EXIF 信息",
      "content": "exiftool \"{{imageFile}}\"",
      "description": "显示图片的所有 EXIF 信息",
      "groupId": 1,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 2,
      "name": "查看常用 EXIF 信息",
      "content": "exiftool -DateTimeOriginal -Model -Make -ISO -ExposureTime -ApertureValue -FNumber \"{{imageFile}}\"",
      "description": "显示图片的常用 EXIF 信息（日期、相机型号、曝光参数等）",
      "groupId": 1,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 3,
      "name": "查看 GPS 信息",
      "content": "exiftool -GPSLatitude -GPSLongitude -GPSAltitude -GPSDateTime \"{{imageFile}}\"",
      "description": "显示图片的 GPS 位置信息",
      "groupId": 1,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 4,
      "name": "修改拍摄日期",
      "content": "exiftool -DateTimeOriginal=\"{{newDate}}\" \"{{imageFile}}\"",
      "description": "修改图片的拍摄日期（格式：YYYY:MM:DD HH:MM:SS）",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "newDate",
          "type": "input",
          "description": "新的拍摄日期（格式：YYYY:MM:DD HH:MM:SS）",
          "options": []
        },
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 5,
      "name": "修改文件创建日期",
      "content": "exiftool -FileCreateDate=\"{{newDate}}\" \"{{imageFile}}\"",
      "description": "修改图片的文件创建日期",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "newDate",
          "type": "input",
          "description": "新的文件创建日期（格式：YYYY:MM:DD HH:MM:SS）",
          "options": []
        },
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 6,
      "name": "添加标题",
      "content": "exiftool -Title=\"{{title}}\" \"{{imageFile}}\"",
      "description": "为图片添加标题",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "title",
          "type": "input",
          "description": "图片标题",
          "options": []
        },
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 7,
      "name": "添加版权信息",
      "content": "exiftool -Copyright=\"{{copyright}}\" \"{{imageFile}}\"",
      "description": "为图片添加版权信息",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "copyright",
          "type": "input",
          "description": "版权信息",
          "options": []
        },
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 8,
      "name": "添加 GPS 坐标",
      "content": "exiftool -GPSLatitude={{latitude}} -GPSLongitude={{longitude}} -GPSLatitudeRef={{latRef}} -GPSLongitudeRef={{longRef}} \"{{imageFile}}\"",
      "description": "为图片添加 GPS 坐标信息（latRef：N/S，longRef：E/W）",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "latitude",
          "type": "number",
          "description": "纬度值",
          "options": []
        },
        {
          "name": "longitude",
          "type": "number",
          "description": "经度值",
          "options": []
        },
        {
          "name": "latRef",
          "type": "input",
          "description": "纬度参考方向（N/S）",
          "options": []
        },
        {
          "name": "longRef",
          "type": "input",
          "description": "经度参考方向（E/W）",
          "options": []
        },
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 9,
      "name": "删除所有 EXIF 信息",
      "content": "exiftool -all= \"{{imageFile}}\"",
      "description": "删除图片的所有 EXIF 信息（会创建备份文件）",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 10,
      "name": "删除 GPS 信息",
      "content": "exiftool -gps:all= \"{{imageFile}}\"",
      "description": "仅删除图片的 GPS 位置信息",
      "groupId": 2,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "imageFile",
          "type": "file",
          "description": "图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 11,
      "name": "转换为 JPEG",
      "content": "magick \"{{inputFile}}\" \"{{outputFile}}.jpg\"",
      "description": "将图片转换为 JPEG 格式",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "input",
          "description": "输出文件名称（不加扩展名）",
          "options": []
        }
      ]
    },
    {
      "id": 12,
      "name": "转换为 PNG",
      "content": "magick \"{{inputFile}}\" \"{{outputFile}}.png\"",
      "description": "将图片转换为 PNG 格式",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "input",
          "description": "输出文件名称（不加扩展名）",
          "options": []
        }
      ]
    },
    {
      "id": 13,
      "name": "调整图片尺寸",
      "content": "magick \"{{inputFile}}\" -resize {{width}}x{{height}} \"{{outputFile}}\"",
      "description": "调整图片尺寸（保持宽高比）",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "width",
          "type": "number",
          "description": "输出图片宽度",
          "options": []
        },
        {
          "name": "height",
          "type": "number",
          "description": "输出图片高度",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "file",
          "description": "输出图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 14,
      "name": "压缩图片",
      "content": "magick \"{{inputFile}}\" -quality {{quality}} \"{{outputFile}}\"",
      "description": "压缩图片质量（1-100，数值越小压缩率越高）",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "quality",
          "type": "number",
          "description": "压缩质量（1-100）",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "file",
          "description": "输出图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 15,
      "name": "裁剪图片",
      "content": "magick \"{{inputFile}}\" -crop {{width}}x{{height}}+{{x}}+{{y}} \"{{outputFile}}\"",
      "description": "裁剪图片（x,y 为左上角坐标）",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "width",
          "type": "number",
          "description": "裁剪宽度",
          "options": []
        },
        {
          "name": "height",
          "type": "number",
          "description": "裁剪高度",
          "options": []
        },
        {
          "name": "x",
          "type": "number",
          "description": "左上角X坐标",
          "options": []
        },
        {
          "name": "y",
          "type": "number",
          "description": "左上角Y坐标",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "file",
          "description": "输出图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 16,
      "name": "旋转图片",
      "content": "magick \"{{inputFile}}\" -rotate {{degrees}} \"{{outputFile}}\"",
      "description": "旋转图片指定度数",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "degrees",
          "type": "number",
          "description": "旋转角度（正数为顺时针）",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "file",
          "description": "输出图片文件路径",
          "options": []
        }
      ]
    },
    {
      "id": 17,
      "name": "批量查看 EXIF",
      "content": "exiftool -r -ext jpg -ext png -ext gif \"{{directory}}\"",
      "description": "递归查看指定目录下所有图片的 EXIF 信息",
      "groupId": 4,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        }
      ]
    },
    {
      "id": 18,
      "name": "批量修改日期",
      "content": "exiftool -overwrite_original -DateTimeOriginal=\"{{newDate}}\" \"{{directory}}\"/*.jpg",
      "description": "批量修改指定目录下所有 JPG 图片的拍摄日期",
      "groupId": 4,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "newDate",
          "type": "input",
          "description": "新的拍摄日期（格式：YYYY:MM:DD HH:MM:SS）",
          "options": []
        },
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        }
      ]
    },
    {
      "id": 19,
      "name": "批量删除 EXIF",
      "content": "exiftool -overwrite_original -all= \"{{directory}}\"/*.jpg",
      "description": "批量删除指定目录下所有 JPG 图片的 EXIF 信息",
      "groupId": 4,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        }
      ]
    },
    {
      "id": 20,
      "name": "批量调整尺寸",
      "content": "cd \"{{directory}}\" && mkdir -p resized && for img in *.jpg; do magick \"$img\" -resize {{maxSize}}x{{maxSize}} \"resized/$img\"; done",
      "description": "批量将目录下所有 JPG 图片调整到指定最大尺寸",
      "groupId": 4,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        },
        {
          "name": "maxSize",
          "type": "number",
          "description": "最大尺寸（宽度和高度）",
          "options": []
        }
      ]
    },
    {
      "id": 21,
      "name": "批量转换格式",
      "content": "cd \"{{directory}}\" && mkdir -p converted && for img in *.{{sourceExt}}; do magick \"$img\" \"converted/${img%.{{sourceExt}}}.{{targetExt}}\"; done",
      "description": "批量将图片从一种格式转换为另一种格式",
      "groupId": 4,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        },
        {
          "name": "sourceExt",
          "type": "input",
          "description": "源文件扩展名（如 jpg）",
          "options": []
        },
        {
          "name": "targetExt",
          "type": "input",
          "description": "目标文件扩展名（如 png）",
          "options": []
        }
      ]
    },
    {
      "id": 22,
      "name": "按日期重命名",
      "content": "exiftool -FileName<DateTimeOriginal -d \"{{directory}}/%Y%m%d_%H%M%S.%%e\" \"{{directory}}\"",
      "description": "按拍摄日期时间批量重命名图片",
      "groupId": 5,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        }
      ]
    },
    {
      "id": 23,
      "name": "按日期组织文件夹",
      "content": "exiftool -Directory<DateTimeOriginal -d \"{{targetDirectory}}/%Y/%Y-%m\" \"{{sourceDirectory}}\"",
      "description": "按拍摄日期将图片组织到年份/月份文件夹中",
      "groupId": 5,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "targetDirectory",
          "type": "directory",
          "description": "目标目录路径",
          "options": []
        },
        {
          "name": "sourceDirectory",
          "type": "directory",
          "description": "源图片目录路径",
          "options": []
        }
      ]
    },
    {
      "id": 24,
      "name": "导出 EXIF 到 CSV",
      "content": "exiftool -csv -DateTimeOriginal -Model -ISO -ExposureTime -ApertureValue -FNumber \"{{directory}}\" > \"{{outputFile}}.csv\"",
      "description": "将指定目录下所有图片的 EXIF 信息导出到 CSV 文件",
      "groupId": 5,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "directory",
          "type": "directory",
          "description": "图片目录路径",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "input",
          "description": "输出CSV文件名称（不加扩展名）",
          "options": []
        }
      ]
    },
    {
      "id": 25,
      "name": "添加水印",
      "content": "magick \"{{inputFile}}\" \"{{watermarkFile}}\" -gravity {{gravity}} -geometry {{offset}} -composite \"{{outputFile}}\"",
      "description": "为图片添加水印（gravity：NorthEast/NorthWest/SouthEast/SouthWest等）",
      "groupId": 3,
      "workspaceId": 0,
      "templateParams": [
        {
          "name": "inputFile",
          "type": "file",
          "description": "输入图片文件路径",
          "options": []
        },
        {
          "name": "watermarkFile",
          "type": "file",
          "description": "水印图片文件路径",
          "options": []
        },
        {
          "name": "gravity",
          "type": "input",
          "description": "水印位置（如 NorthEast）",
          "options": []
        },
        {
          "name": "offset",
          "type": "input",
          "description": "水印偏移量（如 +10+10）",
          "options": []
        },
        {
          "name": "outputFile",
          "type": "file",
          "description": "输出图片文件路径",
          "options": []
        }
      ]
    }
  ],
  "ignored": [
    {
      "pattern": "^ls(\\s.*)?$",
      "isRegex": true
    },
    {
      "pattern": "^cd(\\s.*)?$",
      "isRegex": true
    },
    {
      "pattern": "^pwd(\\s.*)?$",
      "isRegex": true
    },
    {
      "pattern": "^clear(\\s.*)?$",
      "isRegex": true
    }
  ]
}
